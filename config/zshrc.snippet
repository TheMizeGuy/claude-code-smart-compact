# >>> smart-compact zsh >>>
# ctm: launch (or reattach) a named, persistent Claude Code session inside its
# own tmux server — the precondition for self-compaction (a bare-terminal
# session cannot type /compact into itself). `ctm work` creates/reattaches
# session "work" in the current directory; named sessions survive detach.
alias ctm="$HOME/.claude/scripts/claude-tmux.sh"
# <<< smart-compact zsh <<<
